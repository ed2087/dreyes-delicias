<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="gallery-page">
  <div class="gallery-hero">
    <div class="container">
      <h1><%= t.gallery.title %></h1>
    </div>
  </div>

  <%- include('partials/breadcrumbs') %>

  <!-- Album filter -->
  <div class="album-filter">
    <div class="album-filter-inner">
      <a href="/gallery" class="album-pill <%= activeAlbum === 'all' ? 'active' : '' %>"><%= t.gallery.albums.all %></a>
      <% ['food','tacos','burritos','quesadillas','bebidas','postres','taquizas','antojitos','cocina','clientes','setup','truck','events'].forEach(function(key) { %>
      <% if (usedAlbums && usedAlbums.indexOf(key) !== -1) { %>
      <a href="/gallery?album=<%= key %>" class="album-pill <%= activeAlbum === key ? 'active' : '' %>"><%= t.gallery.albums[key] %></a>
      <% } %>
      <% }); %>
    </div>
  </div>

  <!-- Masonry gallery -->
  <% if (photos && photos.length > 0) { %>
  <div class="gallery-masonry" id="galleryMasonry">
    <% photos.forEach(function(photo, i) { %>
    <div class="gallery-masonry-item" data-index="<%= i %>" data-url="<%= photo.url %>">
      <img src="<%= photo.url %>" alt="<%= photo['caption_' + lang] || 'D\'Reyes Delicias' %>" loading="<%= i < 6 ? 'eager' : 'lazy' %>">
      <div class="gallery-masonry-item-overlay">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
      </div>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <div class="gallery-empty">
    <p style="font-size:48px;margin-bottom:12px;">📸</p>
    <p><%= lang === 'es' ? 'No hay fotos aún.' : 'No photos yet.' %></p>
  </div>
  <% } %>

  <!-- Lightbox -->
  <div class="lightbox-backdrop" id="lightboxBackdrop" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <img src="" alt="" class="lightbox-img" id="lightboxImg">
    <button class="lightbox-close" id="lightboxClose" aria-label="Cerrar">&times;</button>
    <button class="lightbox-arrow lightbox-arrow-prev" id="lightboxPrev" aria-label="Anterior">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6"/></svg>
    </button>
    <button class="lightbox-arrow lightbox-arrow-next" id="lightboxNext" aria-label="Siguiente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,18 15,12 9,6"/></svg>
    </button>
  </div>

</main>

<%- include('partials/nav-mobile') %>
<%- include('partials/footer') %>
