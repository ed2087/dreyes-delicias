<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — D'Reyes Delicias CMS</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="/css/admin/admin-global.css">
</head>
<body>
<div class="admin-wrapper">

  <%- include('partials/sidebar', { currentPage: 'dashboard', unreadCount: stats.unreadCount }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="admin-menu-toggle" id="adminMenuToggle" aria-label="Toggle sidebar">
          <span></span><span></span><span></span>
        </button>
        <span class="admin-topbar-title">Dashboard</span>
      </div>
      <div class="admin-topbar-right">
        <span style="font-size:12px;color:rgba(255,255,255,0.3);">Bienvenida, Dilcia 👋</span>
      </div>
    </div>

    <div class="admin-content">

      <!-- Stats -->
      <div class="admin-stat-grid">
        <div class="admin-stat-card">
          <div class="admin-stat-icon">🌮</div>
          <div class="admin-stat-value"><%= stats.menuCount %></div>
          <div class="admin-stat-label">Platillos</div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-icon">📸</div>
          <div class="admin-stat-value"><%= stats.photoCount %></div>
          <div class="admin-stat-label">Fotos</div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-icon">🎉</div>
          <div class="admin-stat-value"><%= stats.serviceCount %></div>
          <div class="admin-stat-label">Servicios</div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-icon">✉️</div>
          <div class="admin-stat-value" style="<%= stats.unreadCount > 0 ? 'color:#fca5a5' : '' %>"><%= stats.unreadCount %></div>
          <div class="admin-stat-label">Sin leer</div>
        </div>
      </div>

      <!-- Quick actions -->
      <div class="admin-section-header" style="margin-bottom:16px;">
        <h2 class="admin-section-title">Acciones rápidas</h2>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:36px;">
        <a href="/admin/menu/new"      class="admin-btn admin-btn-primary">+ Agregar platillo</a>
        <a href="/admin/gallery"       class="admin-btn admin-btn-secondary">📸 Subir fotos</a>
        <a href="/admin/services/new"  class="admin-btn admin-btn-secondary">+ Agregar servicio</a>
        <a href="/admin/location"      class="admin-btn admin-btn-secondary">📍 Actualizar ubicación</a>
      </div>

      <!-- Recent messages -->
      <div class="admin-section-header">
        <h2 class="admin-section-title">Mensajes recientes</h2>
        <a href="/admin/messages" class="admin-btn admin-btn-secondary admin-btn-sm">Ver todos</a>
      </div>

      <% if (recentMessages && recentMessages.length > 0) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Nombre</th><th>Asunto</th><th>Fecha</th><th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <% recentMessages.forEach(function(msg) { %>
            <tr>
              <td style="font-weight:<%= msg.read ? 400 : 700 %>"><%= msg.name %></td>
              <td style="color:rgba(255,255,255,0.5);"><%= msg.subject || '—' %></td>
              <td style="color:rgba(255,255,255,0.4);font-size:12px;"><%= msg.createdAt.toLocaleDateString('es-MX') %></td>
              <td>
                <% if (!msg.read) { %>
                <span style="font-size:11px;font-weight:700;color:var(--admin-gold);">NUEVO</span>
                <% } else { %>
                <span style="font-size:11px;color:rgba(255,255,255,0.3);">Leído</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p style="color:rgba(255,255,255,0.3);font-size:14px;padding:24px 0;">No hay mensajes aún.</p>
      <% } %>

    </div>
  </div>
</div>

<div class="admin-toast-container" id="adminToastContainer"></div>
<script src="/js/admin/admin-global.js"></script>
<% if (typeof pageJS !== 'undefined' && pageJS) { %><script src="/js/<%= pageJS %>.js"></script><% } %>
</body>
</html>
