<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menú — D'Reyes Delicias CMS</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="/css/admin/admin-global.css">
</head>
<body>
<div class="admin-wrapper">

  <%- include('partials/sidebar', { currentPage: 'menu', unreadCount: 0 }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="admin-menu-toggle" id="adminMenuToggle"><span></span><span></span><span></span></button>
        <span class="admin-topbar-title">Menú</span>
      </div>
      <a href="/admin/menu/new" class="admin-btn admin-btn-primary">+ Agregar platillo</a>
    </div>

    <div class="admin-content">
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Foto</th><th>Nombre</th><th>Categoría</th><th>Precio</th><th>Destacado</th><th>Disponible</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (items && items.length > 0) { %>
              <% items.forEach(function(item) { %>
              <tr>
                <td>
                  <% if (item.image && item.image.url) { %>
                  <img src="<%= item.image.url %>" alt="" class="admin-table-thumb">
                  <% } else { %>
                  <div class="admin-table-thumb" style="display:flex;align-items:center;justify-content:center;font-size:20px;">🌮</div>
                  <% } %>
                </td>
                <td style="font-weight:600;"><%= item.name_es %></td>
                <td><span style="font-size:12px;color:var(--admin-gold);text-transform:capitalize;"><%= item.category %></span></td>
                <td>$<%= item.price.toFixed(2) %></td>
                <td><span style="color:<%= item.featured ? 'var(--admin-gold)' : 'rgba(255,255,255,0.2)' %>"><%= item.featured ? '⭐' : '—' %></span></td>
                <td><span style="color:<%= item.available ? '#86efac' : 'rgba(255,255,255,0.3)' %>"><%= item.available ? '✓' : '✗' %></span></td>
                <td>
                  <div class="admin-table-actions">
                    <a href="/admin/menu/<%= item._id %>/edit" class="admin-btn admin-btn-secondary admin-btn-sm">Editar</a>
                    <button class="admin-btn admin-btn-danger admin-btn-sm btn-delete-item" data-id="<%= item._id %>" data-name="<%= item.name_es %>">Eliminar</button>
                  </div>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr><td colspan="7" style="text-align:center;color:rgba(255,255,255,0.3);padding:40px;">No hay platillos. <a href="/admin/menu/new" style="color:var(--admin-gold);">Agrega el primero</a></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="admin-toast-container" id="adminToastContainer"></div>
<script src="/js/admin/admin-global.js"></script>
<script src="/js/admin/admin-menu.js"></script>
</body>
</html>
