<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — D'Reyes Delicias</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="/css/admin/admin-global.css">
  <style>
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; background:#080808; }
    .login-card { width:100%; max-width:380px; padding:0 20px; }
    .login-logo { text-align:center; margin-bottom:32px; }
    .login-logo img { width:64px; height:64px; object-fit:contain; margin:0 auto 12px; }
    .login-logo h1 { font-size:20px; font-weight:700; color:#fff; }
    .login-logo p { font-size:12px; color:rgba(255,255,255,0.3); margin-top:4px; letter-spacing:1px; text-transform:uppercase; }
    .login-form-card { background:#111; border:1px solid rgba(255,255,255,0.07); border-radius:16px; padding:32px 28px; }
    .login-error { background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:8px; padding:10px 14px; font-size:13px; color:#fca5a5; margin-bottom:16px; display:none; }
    .login-submit { width:100%; background:#C9A227; color:#000; font-weight:700; font-size:15px; padding:14px; border-radius:99px; cursor:pointer; border:none; transition:background 0.2s; margin-top:8px; }
    .login-submit:hover { background:#E8C547; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-logo">
      <img src="https://res.cloudinary.com/dwlib8nke/image/upload/v1781222666/logo_web_pnyt9m.png" alt="D'Reyes Delicias">
      <h1>D'Reyes Delicias</h1>
      <p>Panel de administración</p>
    </div>
    <div class="login-form-card">
      <div class="login-error" id="loginError"></div>
      <form id="loginForm">
        <div class="admin-form-group">
          <label class="admin-form-label">Email</label>
          <input type="email" id="loginEmail" class="admin-form-input" placeholder="admin@dreyesdelicias.com" autocomplete="email" required>
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label">Contraseña</label>
          <input type="password" id="loginPassword" class="admin-form-input" placeholder="••••••••" autocomplete="current-password" required>
        </div>
        <button type="submit" class="login-submit" id="loginBtn">Iniciar sesión</button>
      </form>
    </div>
  </div>

  <script src="/js/admin/admin-login.js"></script>
</body>
</html>
