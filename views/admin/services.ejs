<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Servicios — D'Reyes Delicias CMS</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="/css/admin/admin-global.css">
</head>
<body>
<div class="admin-wrapper">

  <%- include('partials/sidebar', { currentPage: 'services', unreadCount: 0 }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="admin-menu-toggle" id="adminMenuToggle"><span></span><span></span><span></span></button>
        <span class="admin-topbar-title">Servicios</span>
      </div>
      <a href="/admin/services/new" class="admin-btn admin-btn-primary">+ Agregar servicio</a>
    </div>

    <div class="admin-content">
      <% if (!services || services.length === 0) { %>
        <div style="text-align:center;padding:80px 20px;color:rgba(255,255,255,0.3);">
          <div style="font-size:48px;margin-bottom:16px;">🎪</div>
          <p style="margin-bottom:20px;">No hay servicios aún.</p>
          <a href="/admin/services/new" class="admin-btn admin-btn-primary">Agregar primer servicio</a>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Imagen</th>
                <th>Nombre</th>
                <th>Descripción corta</th>
                <th>Destacado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% services.forEach(function(service) { %>
                <tr>
                  <td>
                    <% if (service.image && service.image.url) { %>
                      <img src="<%= service.image.url %>" alt="" class="admin-table-thumb">
                    <% } else { %>
                      <div class="admin-table-thumb" style="display:flex;align-items:center;justify-content:center;font-size:20px;">🎪</div>
                    <% } %>
                  </td>
                  <td style="font-weight:600;">
                    <%= service.name_es %>
                    <% if (service.name_en) { %>
                      <div style="font-size:12px;color:rgba(255,255,255,0.4);font-weight:400;margin-top:2px;"><%= service.name_en %></div>
                    <% } %>
                  </td>
                  <td style="font-size:13px;color:rgba(255,255,255,0.5);max-width:200px;">
                    <%= service.shortDesc_es ? service.shortDesc_es.substring(0, 60) + (service.shortDesc_es.length > 60 ? '…' : '') : '—' %>
                  </td>
                  <td>
                    <span style="color:<%= service.featured ? 'var(--admin-gold)' : 'rgba(255,255,255,0.2)' %>">
                      <%= service.featured ? '⭐ Sí' : '—' %>
                    </span>
                  </td>
                  <td>
                    <div class="admin-table-actions">
                      <a href="/admin/services/<%= service._id %>/edit" class="admin-btn admin-btn-secondary admin-btn-sm">Editar</a>
                      <button class="admin-btn admin-btn-danger admin-btn-sm btn-delete-service" data-id="<%= service._id %>" data-name="<%= service.name_es %>">Eliminar</button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div class="admin-toast-container" id="adminToastContainer"></div>
<script src="/js/admin/admin-global.js"></script>
<script src="/js/admin/admin-services.js"></script>
</body>
</html>
