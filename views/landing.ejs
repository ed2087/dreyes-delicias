<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>

  <!-- ── Hero ────────────────────────────────────────────────────────────────── -->
  <section class="hero" id="hero" aria-label="Hero">
    <div class="hero-bg" id="heroBg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-glow"></div>

    <div class="hero-content">
      <div class="hero-logo-wrap">
        <img src="/images/logo.PNG" alt="D'Reyes Delicias" class="hero-logo" width="140" height="140">
      </div>
      <p class="hero-label"><%= t.hero.tagline %></p>
      <h1 class="hero-title">
        D'Reyes
        <span class="gold-word">Delicias</span>
      </h1>
      <p class="hero-subtitle"><%= t.hero.subtitle %></p>
      <div class="hero-ctas">
        <a href="/menu"    class="btn btn-primary btn-lg"><%= t.hero.cta_menu %></a>
        <a href="/contact" class="btn btn-secondary btn-lg"><%= t.hero.cta_contact %></a>
      </div>
    </div>

    <div class="hero-scroll-hint" aria-hidden="true">
      <div class="scroll-mouse"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ── Services Strip ──────────────────────────────────────────────────────── -->
  <section class="services-strip section" id="services">
    <div class="container">
      <div class="section-heading reveal">
        <span class="section-label"><%= t.sections.services %></span>
        <h2><%= t.sections.services %></h2>
      </div>

      <div class="services-grid">
        <% if (typeof services !== 'undefined' && services && services.length > 0) { %>
          <% services.slice(0, 3).forEach(function(service, i) { %>
            <%
              var svcName  = service['name_' + lang] || service.name_es;
              var svcShort = service['shortDesc_' + lang] || service.shortDesc_es || '';
              var svcImg   = (service.gallery && service.gallery.length > 0)
                               ? service.gallery[0].url
                               : (service.image && service.image.url ? service.image.url : null);
            %>
            <a href="/services/<%= service.slug %>" class="service-card-preview reveal reveal-delay-<%= i+1 %>">
              <% if (svcImg) { %>
                <img src="<%= svcImg %>" alt="<%= svcName %>" class="service-card-img" loading="lazy">
              <% } %>
              <div class="service-card-overlay"></div>
              <div class="service-card-body">
                <div class="service-card-name"><%= svcName %></div>
                <% if (svcShort) { %><div class="service-card-desc"><%= svcShort %></div><% } %>
                <span class="service-card-arrow"><%= lang === 'es' ? 'Ver más' : 'Learn more' %> →</span>
              </div>
            </a>
          <% }); %>
        <% } %>
      </div>
    </div>
  </section>

  <!-- ── Gallery Slider ──────────────────────────────────────────────────────── -->
  <section class="gallery-slider-section" id="gallery-preview">
    <div class="section-heading reveal">
      <span class="section-label"><%= t.sections.gallery %></span>
      <h2><%= t.sections.gallery %></h2>
    </div>

    <div class="slider-stage-wrapper" id="sliderStageWrapper">
      <div class="slider-stage" id="sliderStage">
        <% if (typeof featuredPhotos !== 'undefined' && featuredPhotos && featuredPhotos.length > 0) { %>
          <% featuredPhotos.forEach(function(photo, i) { %>
          <div class="slider-card" data-index="<%= i %>">
            <img src="<%= photo.url %>" alt="<%= photo['caption_' + lang] || 'D\'Reyes Delicias' %>" loading="<%= i < 3 ? 'eager' : 'lazy' %>">
            <div class="slider-card-overlay">
              <span class="slider-card-caption"><%= photo['caption_' + lang] || '' %></span>
            </div>
          </div>
          <% }); %>
        <% } else { %>
          <!-- Placeholders — replace with real photos via CMS -->
          <% for(var i = 0; i < 5; i++) { %>
          <div class="slider-card slider-card-placeholder" data-index="<%= i %>">
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a1a1a,#2a2a1a);display:flex;align-items:center;justify-content:center;font-size:48px;">🌮</div>
          </div>
          <% } %>
        <% } %>
      </div>

      <button class="slider-arrow slider-arrow-prev" id="sliderPrev" aria-label="Anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6"/></svg>
      </button>
      <button class="slider-arrow slider-arrow-next" id="sliderNext" aria-label="Siguiente">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,18 15,12 9,6"/></svg>
      </button>
    </div>

    <div class="slider-dots" id="sliderDots"></div>
    <p class="slider-swipe-hint">← Desliza para ver más →</p>

    <div class="gallery-view-all">
      <a href="/gallery" class="btn btn-secondary"><%= t.sections.gallery_cta %></a>
    </div>
  </section>

  <!-- ── Featured Menu ───────────────────────────────────────────────────────── -->
  <section class="featured-menu-section section" id="menu-preview">
    <div class="container">
      <div class="section-heading reveal">
        <span class="section-label"><%= t.sections.menu %></span>
        <h2><%= t.sections.menu %></h2>
      </div>
    </div>

    <div class="mcs-wrapper" id="mcsWrapper">
      <button class="mcs-arrow mcs-arrow--prev" id="mcsArrowPrev" aria-label="Anterior" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15,18 9,12 15,6"/></svg>
      </button>

      <div class="menu-cards-scroll" id="menuCardsScroll">
        <% if (typeof featuredDishes !== 'undefined' && featuredDishes && featuredDishes.length > 0) { %>
          <% featuredDishes.forEach(function(item) { %>
          <a href="/menu/<%= item.slug %>" class="menu-card-preview">
            <div class="mcp-img">
              <% if (item.image && item.image.url) { %>
              <img src="<%= item.image.url %>" alt="<%= item['name_' + lang] %>" loading="lazy">
              <% } %>
              <span class="mcp-category"><%= t.menu.categories[item.category] || item.category %></span>
              <% if (item.spiceLevel && item.spiceLevel > 0) { %>
              <div class="mcp-spice" aria-label="Picante <%= item.spiceLevel %>/3">
                <% for (var d = 1; d <= 3; d++) { %><span class="mcp-dot<%= d <= item.spiceLevel ? '' : ' mcp-dot-off' %>"></span><% } %>
              </div>
              <% } %>
              <div class="mcp-body">
                <div class="mcp-name"><%= item['name_' + lang] %></div>
                <div class="mcp-price">$<%= item.price.toFixed(2) %></div>
              </div>
              <div class="mcp-arrow">&#8594;</div>
            </div>
          </a>
          <% }); %>
        <% } else { %>
          <% var placeholders = ['Tacos al Pastor', 'Burrito de Carne', 'Quesadilla Especial', 'Enchiladas Verdes', 'Sopes de Tinga']; %>
          <% placeholders.forEach(function(name) { %>
          <div class="menu-card-preview">
            <div class="mcp-img" style="background:#1a1007;aspect-ratio:3/4;">
              <div class="mcp-body">
                <div class="mcp-name"><%= name %></div>
                <div class="mcp-price">—</div>
              </div>
            </div>
          </div>
          <% }); %>
        <% } %>
      </div>

      <button class="mcs-arrow mcs-arrow--next" id="mcsArrowNext" aria-label="Siguiente">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9,18 15,12 9,6"/></svg>
      </button>
    </div>

    <div class="mcs-footer">
      <div class="mcs-progress-wrap">
        <div class="mcs-progress-bar" id="mcsProgressBar"></div>
      </div>
      <p class="mcs-swipe-hint">← Desliza para ver más →</p>
    </div>

    <div class="container" style="margin-top:28px;text-align:center;">
      <a href="/menu" class="btn btn-primary"><%= t.sections.menu_cta %></a>
    </div>
  </section>

  <!-- ── Live Location ───────────────────────────────────────────────────────── -->
  <section class="location-section section" id="location-preview">
    <div class="container">
      <div class="section-heading reveal">
        <span class="section-label"><%= lang === 'es' ? 'UBICACIÓN' : 'LOCATION' %></span>
        <h2><%= t.sections.location %></h2>
      </div>

      <div class="location-inner">
        <div class="location-info">
          <!-- Address card -->
          <div class="loc-card reveal">
            <div class="loc-card-icon">📍</div>
            <div class="loc-card-body">
              <strong class="loc-card-label"><%= t.location.address %></strong>
              <% var lAddr = location ? location.address : '437 Morgan Mill Rd, Monroe, NC 28110'; %>
              <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(lAddr) %>" target="_blank" rel="noopener noreferrer" class="landing-addr-link"><%= lAddr %></a>
            </div>
          </div>

          <!-- Hours card -->
          <div class="loc-card reveal reveal-delay-1">
            <div class="loc-card-icon">🕐</div>
            <div class="loc-card-body">
              <strong class="loc-card-label"><%= t.location.hours %></strong>
              <div class="landing-hours-list">
                <% var lDays = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
                   lDays.forEach(function(dayKey) {
                     var dData = location && location.hours && location.hours[dayKey];
                     var isActive = dData && dData.active;
                     var dOpen  = dData ? dData.open  : '4:00 PM';
                     var dClose = dData ? dData.close : '10:00 PM';
                %>
                <div class="lhl-row <%= isActive ? '' : 'lhl-row--closed' %>">
                  <span class="lhl-day"><%= t.location.days[dayKey] %></span>
                  <span class="lhl-time"><%= isActive ? (dOpen + ' – ' + dClose) : (lang === 'es' ? 'Cerrado' : 'Closed') %></span>
                </div>
                <% }) %>
              </div>
              <% if (location && ((lang === 'es' ? location.note_es : location.note_en))) { %>
              <p class="landing-hours-note"><%= lang === 'es' ? location.note_es : location.note_en %></p>
              <% } %>
            </div>
          </div>

          <div class="location-ctas reveal reveal-delay-2">
            <a href="https://wa.me/19802714205?text=<%= encodeURIComponent(lang === 'es' ? 'Hola D\'Reyes Delicias 👑 Me gustaría obtener información sobre sus taquizas y banquetes.' : 'Hi D\'Reyes Delicias 👑 I would like to get information about your taquiza and banquet services.') %>" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp location-cta-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <%= lang === 'es' ? 'Escríbenos' : 'WhatsApp' %>
            </a>
            <a href="tel:+19802714205" class="btn btn-secondary location-cta-btn">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (980) 271-4205
            </a>
          </div>
        </div>

        <div class="location-map">
          <% var mapLat = (location && location.lat) ? location.lat : 34.9854; %>
          <% var mapLng = (location && location.lng) ? location.lng : -80.5538; %>
          <iframe
            src="https://www.google.com/maps?q=<%= mapLat %>,<%= mapLng %>&z=16&output=embed"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            title="D'Reyes Delicias Location">
          </iframe>
          <% if (location && !locationIsOpen) { %>
          <div class="map-closed-overlay">
            <div class="map-closed-badge">
              <span class="map-closed-icon">🔴</span>
              <p class="map-closed-text"><%= lang === 'es' ? 'Cerrado hoy' : 'Closed today' %></p>
            </div>
          </div>
          <% } %>
          <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(lAddr) %>" target="_blank" rel="noopener noreferrer" class="loc-map-btn">
            <%= lang === 'es' ? 'Ver en Google Maps' : 'Open in Google Maps' %> ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Featured Partner Spotlight ──────────────────────────────────────────── -->
  <% if (typeof allies !== 'undefined' && allies && allies.length > 0) { %>
  <section class="ally-section" aria-label="Colaboradores destacados">

    <div class="ally-section-head">
      <span class="section-label"><%= t.sections.allies %></span>
      <h2><%= t.sections.negocios %></h2>
      <p><%= t.sections.negocios_sub %></p>
    </div>

    <div class="ally-stage-wrap">
    <div class="ally-stage" id="allyStage">
      <% allies.forEach(function(ally, idx) {
           var aLink   = ally.link || '';
           var aHref   = aLink;
           var aLabel  = ally.ctaText || '';
           var aTarget = '_blank';
           var aRel    = 'noopener noreferrer';
           if (aLink) {
             var phoneRe = /^\+?1?\s?\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$/;
             if (/^tel:/.test(aLink) || phoneRe.test(aLink.trim())) {
               if (!aLink.startsWith('tel:')) aHref = 'tel:' + aLink.replace(/[^\d+]/g, '');
               if (!aLabel) aLabel = aHref.replace('tel:', '');
               aTarget = '_self'; aRel = '';
             } else if (/wa\.me|whatsapp/i.test(aLink)) {
               if (!aLabel) aLabel = 'WhatsApp';
             } else if (/instagram\.com/i.test(aLink)) {
               if (!aLabel) aLabel = 'Instagram';
             } else if (/facebook\.com/i.test(aLink)) {
               if (!aLabel) aLabel = 'Facebook';
             } else if (/tiktok\.com/i.test(aLink)) {
               if (!aLabel) aLabel = 'TikTok';
             } else {
               if (!aLabel) aLabel = lang === 'es' ? 'Visitar sitio' : 'Visit Website';
             }
           }
      %>
      <article class="ally-card <%= idx === 0 ? 'active' : '' %>" data-index="<%= idx %>">
        <div class="ally-card-inner">

          <% var allyProfileHref = ally.slug ? '/negocios/' + ally.slug : null; %>
          <% if (allyProfileHref) { %>
          <a href="<%= allyProfileHref %>" class="ally-visual" aria-label="<%= lang === 'es' ? 'Ver perfil de ' + ally.name : 'View ' + ally.name + ' profile' %>">
          <% } else { %>
          <div class="ally-visual">
          <% } %>
            <% if (ally.image && ally.image.url) { %>
            <img src="<%= ally.image.url %>" alt="<%= ally.name %>" class="ally-visual-img" loading="<%= idx === 0 ? 'eager' : 'lazy' %>">
            <% } else { %>
            <div class="ally-visual-fallback">🤝</div>
            <% } %>
            <div class="ally-visual-overlay"></div>
          <% if (allyProfileHref) { %></a><% } else { %></div><% } %>

          <div class="ally-panel">
            <p class="ally-kicker"><%= t.sections.allies || 'FEATURED PARTNER' %></p>
            <% if (allyProfileHref) { %>
            <a href="<%= allyProfileHref %>" class="ally-name-link"><h2 class="ally-name"><%= ally.name %></h2></a>
            <% } else { %>
            <h2 class="ally-name"><%= ally.name %></h2>
            <% } %>
            <% var allyShort = (lang === 'en' && ally.shortDescEn) ? ally.shortDescEn : (ally.shortDesc || ally.description); %>
            <% if (allyShort) { %>
            <p class="ally-desc"><%= allyShort %></p>
            <% } %>
            <div class="ally-ctas-row">
            <% if (aLink) { %>
            <a href="<%= aHref %>" target="<%= aTarget %>" <%- aRel ? 'rel="' + aRel + '"' : '' %> class="ally-cta">
              <%= aLabel %>
              <% if (aTarget === '_blank') { %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              <% } %>
            </a>
            <% } %>
            <% if (allyProfileHref) { %>
            <a href="<%= allyProfileHref %>" class="ally-profile-link"><%= lang === 'es' ? 'Ver perfil →' : 'View profile →' %></a>
            <% } %>
            </div>
          </div>

        </div>
      </article>
      <% }); %>
    </div>
    </div>

    <% if (allies.length > 1) { %>
    <div class="ally-dots" id="allyDots">
      <% allies.forEach(function(_, idx) { %>
      <button class="ally-dot <%= idx === 0 ? 'active' : '' %>" data-goto="<%= idx %>" aria-label="Partner <%= idx + 1 %>"></button>
      <% }); %>
    </div>
    <% } %>

    <div class="ally-section-cta">
      <a href="/negocios" class="btn btn-secondary"><%= t.sections.negocios_cta %></a>
    </div>

  </section>
  <% } %>

</main>

<!-- Gallery lightbox (triggered by landing slider) -->
<div class="slb-backdrop" id="sliderLightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <button class="slb-close" aria-label="Close">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="slb-arrow slb-prev" aria-label="Previous photo">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15,18 9,12 15,6"/></svg>
  </button>
  <div class="slb-content">
    <img class="slb-img" src="" alt="Gallery photo">
    <p class="slb-caption"></p>
  </div>
  <button class="slb-arrow slb-next" aria-label="Next photo">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9,18 15,12 9,6"/></svg>
  </button>
</div>

<%- include('partials/nav-mobile') %>
<%- include('partials/footer') %>
