<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/nav-mobile') %>

<main class="error-page">
  <div class="error-content">
    <div class="error-code"><%= statusCode || 404 %></div>
    <h1 class="error-title">
      <%= statusCode === 404 ? t.error['404_title'] : t.error['500_title'] %>
    </h1>
    <p class="error-message">
      <%= statusCode === 404 ? t.error['404_message'] : t.error['500_message'] %>
    </p>
    <a href="/" class="btn btn-primary btn-lg"><%= t.error.go_home %></a>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/social-bubble') %>

</body>
</html>
