    <!-- Call -->
    <a class="sb-btn sb-btn--call" href="tel:+19802714205" aria-label="Llamar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
      <span class="sb-label"><%= lang === 'es' ? 'Llamar' : 'Call' %></span>
    </a>

    <!-- Google Reviews -->
    <a class="sb-btn sb-btn--google"
       href="https://www.google.com/maps/search/D'Reyes+Delicias+Monroe+NC/"
       target="_blank" rel="noopener noreferrer" aria-label="Reseña en Google">
      <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      <span class="sb-label"><%= lang === 'es' ? 'Reseña Google' : 'Google Review' %></span>
    </a>

    <!-- Nanarii -->
    <a class="sb-btn sb-btn--nanarii"
       href="https://www.nanarii.com/negocios/north-carolina/monroe/dreyes-delicias-monroe"
       target="_blank" rel="noopener noreferrer" aria-label="Reseña en Nanarii">
      <img src="/images/favicon-nanarii.ico" width="22" height="22" alt="" aria-hidden="true" style="object-fit:contain;border-radius:3px;">
      <span class="sb-label">Nanarii</span>
    </a>

    <!-- TikTok -->
    <a class="sb-btn sb-btn--tiktok"
       href="https://www.tiktok.com/@dreyesdelicias_oficial"
       target="_blank" rel="noopener noreferrer" aria-label="TikTok">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.28 6.28 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.74a4.85 4.85 0 01-1.01-.05z"/>
      </svg>
      <span class="sb-label">TikTok</span>
    </a>

    <!-- Share current page -->
    <button class="sb-btn sb-btn--share" id="sbShare"
            data-title="<%= seo.title %> | D'Reyes Delicias"
            data-url="<%= seo.canonicalUrl %>"
            aria-label="<%= lang === 'es' ? 'Compartir esta página' : 'Share this page' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
      <span class="sb-label sb-share-label"><%= lang === 'es' ? 'Compartir' : 'Share' %></span>
    </button>

  </div>

  <!-- Toggle tab — always visible -->
  <button class="sb-toggle" id="sbToggle"
          aria-label="<%= lang === 'es' ? 'Acciones rápidas' : 'Quick actions' %>"
          aria-expanded="false" aria-controls="sbActions">
    <svg class="sb-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
    </svg>
    <svg class="sb-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

</div>

<script>
(function () {
  var bubble  = document.getElementById('socialBubble');
  var toggle  = document.getElementById('sbToggle');
  var actions = document.getElementById('sbActions');
  var share   = document.getElementById('sbShare');
  if (!bubble || !toggle) return;

  function openBubble()  { bubble.classList.add('open');    toggle.setAttribute('aria-expanded','true');  actions.setAttribute('aria-hidden','false'); }
  function closeBubble() { bubble.classList.remove('open'); toggle.setAttribute('aria-expanded','false'); actions.setAttribute('aria-hidden','true');  }

  toggle.addEventListener('click', function () {
    bubble.classList.contains('open') ? closeBubble() : openBubble();
  });

  document.addEventListener('click', function (e) {
    if (!bubble.contains(e.target)) closeBubble();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeBubble();
  });

  if (share) {
    share.addEventListener('click', function () {
      var title = this.dataset.title;
      var url   = this.dataset.url;
      var label = this.querySelector('.sb-share-label');
      if (navigator.share) {
        navigator.share({ title: title, url: url }).catch(function(){});
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(function () {
          if (label) {
            var orig = label.textContent;
            label.textContent = '¡Copiado!';
            setTimeout(function () { label.textContent = orig; }, 2000);
          }
        });
      }
    });
  }
})();
</script>
