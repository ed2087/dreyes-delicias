<div class="modal-backdrop" id="confirmModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="confirmModalTitle">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title" id="confirmModalTitle">Confirmar</h3>
      <button class="modal-close-btn" data-action="close-modal" data-modal="confirmModalBackdrop" aria-label="Cerrar">&times;</button>
    </div>
    <div class="modal-body">
      <div class="confirm-modal-content">
        <div class="confirm-icon" id="confirmIcon">⚠️</div>
        <p class="confirm-message" id="confirmMessage">¿Estás seguro?</p>
        <div class="confirm-buttons">
          <button class="btn btn-danger btn-confirm" id="confirmBtn">Confirmar</button>
          <button class="btn btn-secondary" data-action="close-modal" data-modal="confirmModalBackdrop">Cancelar</button>
        </div>
      </div>
    </div>
  </div>
</div>
