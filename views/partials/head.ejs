<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-25Q6D1ZTFC"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-25Q6D1ZTFC');
  </script>

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="preconnect" href="https://www.google-analytics.com">

  <!-- Primary SEO -->
  <title><%= seo.title %> | <%= seo.siteName %></title>
  <meta name="description" content="<%= seo.description %>">
  <% if (seo.keywords) { %>
  <meta name="keywords" content="<%= seo.keywords %>">
  <% } %>
  <link rel="canonical" href="<%= seo.canonicalUrl %>">

  <!-- Robots -->
  <meta name="robots" content="<%= seo.noIndex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1' %>">

  <!-- Geo targeting — Monroe, NC -->
  <meta name="geo.region" content="US-NC">
  <meta name="geo.placename" content="Monroe, North Carolina">
  <meta name="geo.position" content="34.9851;-80.5492">
  <meta name="ICBM" content="34.9851, -80.5492">

  <!-- Open Graph -->
  <meta property="og:type"             content="<%= seo.type %>">
  <meta property="og:url"              content="<%= seo.canonicalUrl %>">
  <meta property="og:title"            content="<%= seo.title %> | <%= seo.siteName %>">
  <meta property="og:description"      content="<%= seo.description %>">
  <meta property="og:image"            content="<%= seo.imageUrl %>">
  <meta property="og:image:width"      content="1200">
  <meta property="og:image:height"     content="630">
  <meta property="og:site_name"        content="<%= seo.siteName %>">
  <meta property="og:locale"           content="<%= lang === 'en' ? 'en_US' : 'es_MX' %>">
  <meta property="og:locale:alternate" content="<%= lang === 'en' ? 'es_MX' : 'en_US' %>">

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:site"        content="@dreyesdelicias">
  <meta name="twitter:title"       content="<%= seo.title %> | <%= seo.siteName %>">
  <meta name="twitter:description" content="<%= seo.description %>">
  <meta name="twitter:image"       content="<%= seo.imageUrl %>">

  <!-- JSON-LD — FoodEstablishment / LocalBusiness -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["FoodEstablishment", "LocalBusiness"],
    "name": "D'Reyes Delicias",
    "description": "<%= seo.description %>",
    "url": "https://www.dreyesdelicias.com",
    "image": "<%= seo.imageUrl %>",
    "logo": "https://www.dreyesdelicias.com/images/logo.png",
    "telephone": "+19802714205",
    "email": "dreyesdelicias@gmail.com",
    "priceRange": "$$",
    "currenciesAccepted": "USD",
    "paymentAccepted": "Cash, Credit Card, Zelle, CashApp",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "437 Morgan Mill Rd",
      "addressLocality": "Monroe",
      "addressRegion": "NC",
      "postalCode": "28110",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 34.9851,
      "longitude": -80.5492
    },
    "hasMap": "https://maps.google.com/?q=437+Morgan+Mill+Rd+Monroe+NC+28110",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Wednesday", "Thursday"],
        "opens": "16:00",
        "closes": "22:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Friday", "Saturday"],
        "opens": "16:00",
        "closes": "23:00"
      }
    ],
    "servesCuisine": ["Mexican", "Latin American", "Tex-Mex"],
    "menu": "https://www.dreyesdelicias.com/menu",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Catering Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Taquiza a Domicilio" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Banquete Completo" } }
      ]
    },
    "areaServed": [
      { "@type": "City", "name": "Monroe", "sameAs": "https://en.wikipedia.org/wiki/Monroe,_North_Carolina" },
      { "@type": "AdministrativeArea", "name": "Union County, NC" },
      { "@type": "City", "name": "Matthews" },
      { "@type": "City", "name": "Waxhaw" },
      { "@type": "City", "name": "Mint Hill" }
    ],
    "sameAs": [
      "https://www.facebook.com/dreyesdelicias",
      "https://www.instagram.com/dreyesdelicias1",
      "https://www.tiktok.com/@dreyesdelicias"
    ]
  }
  </script>

  <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs && breadcrumbs.length > 1) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      <% breadcrumbs.forEach((crumb, i) => { %>
      {
        "@type": "ListItem",
        "position": <%= i + 1 %>,
        "name": "<%= crumb.name %>",
        "item": "https://www.dreyesdelicias.com<%= crumb.url %>"
      }<%= i < breadcrumbs.length - 1 ? ',' : '' %>
      <% }); %>
    ]
  }
  </script>
  <% } %>

  <!-- Favicon -->
  <link rel="icon" href="/images/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <!-- Theme color (mobile browser chrome) -->
  <meta name="theme-color" content="#c9a227">

  <!-- Global CSS -->
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/partials/nav.css">
  <link rel="stylesheet" href="/css/partials/nav-mobile.css">
  <link rel="stylesheet" href="/css/partials/social-bubble.css">

  <!-- Page CSS -->
  <% if (typeof pageCSS !== 'undefined' && pageCSS) { %>
  <link rel="stylesheet" href="/css/<%= pageCSS %>.css">
  <% } %>

  <!-- Partial CSS -->
  <% if (typeof partialCSS !== 'undefined' && partialCSS) { %>
    <% partialCSS.forEach(function(css) { %>
  <link rel="stylesheet" href="/css/partials/<%= css %>.css">
    <% }); %>
  <% } %>
</head>
<body>
