<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="negocios-page">
  <div class="negocios-hero">
    <div class="container">
      <span class="section-label"><%= lang === 'es' ? 'NEGOCIOS' : 'BUSINESSES' %></span>
      <h1><%= t.negocios.title %></h1>
      <p class="negocios-hero-sub"><%= t.negocios.subtitle %></p>
    </div>
  </div>

  <%- include('partials/breadcrumbs') %>

  <div class="negocios-grid container">
    <% if (negocios && negocios.length > 0) { %>
      <% negocios.forEach(function(neg) {
           var link = neg.link || '';
           var href = link;
           var ctaLabel = neg.ctaText || '';
           var ctaIcon  = 'web';
           if (!ctaLabel) {
             if (/^tel:|^\+?1?\s?\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$/.test(link.trim())) {
               if (!link.startsWith('tel:')) href = 'tel:' + link.replace(/[^\d+]/g, '');
               ctaLabel = t.negocios.cta_call; ctaIcon = 'phone';
             } else if (/wa\.me|whatsapp/i.test(link)) {
               ctaLabel = t.negocios.cta_whatsapp; ctaIcon = 'whatsapp';
             } else if (/instagram\.com/i.test(link)) {
               ctaLabel = 'Instagram'; ctaIcon = 'instagram';
             } else if (/facebook\.com/i.test(link)) {
               ctaLabel = 'Facebook'; ctaIcon = 'facebook';
             } else if (/tiktok\.com/i.test(link)) {
               ctaLabel = 'TikTok'; ctaIcon = 'tiktok';
             } else {
               ctaLabel = t.negocios.cta_website; ctaIcon = 'web';
             }
           }
      %>
      <a href="<%= neg.slug ? '/negocios/' + neg.slug : '#' %>" class="neg-card reveal">
        <div class="neg-card-img">
          <% if (neg.image && neg.image.url) { %>
          <img src="<%= neg.image.url %>" alt="<%= neg.name %>" loading="lazy">
          <% } else { %>
          <div class="neg-card-placeholder">🤝</div>
          <% } %>
          <% if (neg.category) { %><span class="neg-card-cat"><%= neg.category %></span><% } %>
        </div>
        <div class="neg-card-body">
          <h2 class="neg-card-name"><%= neg.name %></h2>
          <p class="neg-card-desc"><%= (lang === 'en' && neg.shortDescEn) ? neg.shortDescEn : (neg.shortDesc || neg.description) %></p>
          <% if (link) { %>
          <span class="neg-card-cta">
            <% if (ctaIcon === 'phone') { %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            <% } %>
            <%= ctaLabel %> →
          </span>
          <% } %>
        </div>
      </a>
      <% }) %>
    <% } else { %>
    <p class="negocios-empty"><%= t.negocios.empty %></p>
    <% } %>
  </div>

  <!-- Promote your business CTA -->
  <div class="negocios-promote container">
    <p><%= t.negocios.promote_cta %></p>
    <a href="/contact" class="btn btn-primary"><%= t.negocios.promote_link %></a>
  </div>

</main>

<%- include('partials/nav-mobile') %>
<%- include('partials/footer') %>
