<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="location-page">
  <div style="background:var(--bg-secondary);padding:48px 0 40px;border-bottom:1px solid var(--border);text-align:center;">
    <div class="container">
      <h1 style="font-family:var(--font-display);"><%= t.location.title %></h1>
    </div>
  </div>

  <%- include('partials/breadcrumbs') %>

  <div class="location-page-inner">

    <% if (location && location.embedUrl) { %>
    <div class="location-map-full">
      <iframe src="<%= location.embedUrl %>" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" title="D'Reyes Delicias Location"></iframe>
    </div>
    <% } else { %>
    <div class="location-map-full">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3268.5!2d-80.55!3d34.985!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s437+Morgan+Mill+Rd+Monroe+NC!5e0!3m2!1sen!2sus!4v1" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" title="D'Reyes Delicias Location"></iframe>
    </div>
    <% } %>

    <div class="location-details-card">
      <div class="location-info-row">
        <div class="location-info-icon">📍</div>
        <div class="location-info-text">
          <strong><%= t.location.address %></strong>
          <p><%= location ? location.address : '437 Morgan Mill Rd, Monroe, NC 28110' %></p>
          <% if (location && location.googleMapsUrl) { %>
          <a href="<%= location.googleMapsUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-sm" style="padding:6px 0;margin-top:4px;">
            <%= lang === 'es' ? 'Abrir en Google Maps →' : 'Open in Google Maps →' %>
          </a>
          <% } %>
        </div>
      </div>

      <div>
        <strong style="font-size:13px;letter-spacing:0.5px;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:14px;"><%= t.location.hours %></strong>
        <div class="location-hours-grid">
          <% var locationDays = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
             locationDays.forEach(function(dayKey) {
               var dayData = location && location.hours && location.hours[dayKey];
               if (!dayData || !dayData.active) return;
          %>
          <div class="hours-day-card">
            <div class="hours-day-name"><%= t.location.days[dayKey] %></div>
            <div class="hours-day-time"><%= dayData.open %> – <%= dayData.close %></div>
          </div>
          <% }) %>
        </div>
        <% if (location && ((lang === 'es' ? location.note_es : location.note_en))) { %>
        <p style="margin-top:12px;font-size:13px;color:var(--gold);font-style:italic;"><%= lang === 'es' ? location.note_es : location.note_en %></p>
        <% } %>
      </div>

      <div class="location-actions">
        <a href="https://wa.me/19802714205" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp location-action-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <%= t.contact.whatsapp %>
        </a>
        <a href="tel:+19802714205" class="btn btn-secondary location-action-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <%= lang === 'es' ? 'Llamar' : 'Call' %> (980) 271-4205
        </a>
      </div>
    </div>

  </div>
</main>

<%- include('partials/nav-mobile') %>
<%- include('partials/footer') %>
